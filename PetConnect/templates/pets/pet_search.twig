{% extends 'base.twig' %}
{% block title %}{{ translations['pet_search.title']|default('Search Results') }}: {{ query }}{% endblock %}
{% block content %}
<h1>{{ translations['pet_search.title']|default('Search Results') }} "{{ query }}"</h1>
<p>{{ pets|length }} {{ translations['pet_search.found']|default('pet(s) found.') }}</p>

{% if pets is empty %}
    <p>{{ translations['pet_search.no_results']|default('No pets matched your search.') }} <a href="{{ base_path }}/pets">{{ translations['pet_search.browse_all']|default('Browse all pets') }}</a>.</p>
{% else %}
    <div class="pet-grid">
        {% for pet in pets %}
            {% set _counts = {'dog': 4, 'cat': 4, 'rabbit': 4, 'bird': 3} %}
            {% set _species = pet.species|lower %}
            {% if pet.image %}
                {% set _pet_img = base_path ~ pet.image %}
            {% elseif _counts[_species] is defined %}
                {% set _pet_img = base_path ~ '/Assets/images/' ~ _species ~ ((pet.id % _counts[_species]) + 1) ~ '.jpg' %}
            {% else %}
                {% set _pet_img = base_path ~ '/Assets/images/default-pet.svg' %}
            {% endif %}
            <article class="pet-card">
                <a href="{{ base_path }}/pets/{{ pet.id }}">
                    <img src="{{ _pet_img }}" alt="{{ pet.name }}" class="pet-card__img">
                    <div class="pet-card__body">
                        <h2>{{ pet.name }}</h2>
                        <p>{{ pet.breed }} · {{ pet.age }} {{ translations['pet_detail.years']|default('yrs') }}</p>
                        <span class="badge badge--{{ pet.status }}">{{ pet.status }}</span>
                    </div>
                </a>
            </article>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
